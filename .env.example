# ─── Shopify App Credentials ─────────────────────────────────────────────────
# Found in your Shopify Partner Dashboard → Apps → Your App → App setup
SHOPIFY_CLIENT_ID=your_shopify_client_id_here
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here

# Scopes requested during OAuth. Adjust if you need additional API access.
SHOPIFY_SCOPES=read_products,read_inventory,read_orders

# ─── Your Shopify Store ───────────────────────────────────────────────────────
# The .myshopify.com domain for your store
SHOPIFY_SHOP=tzr7sd-ii.myshopify.com

# ─── Server ───────────────────────────────────────────────────────────────────
# The publicly accessible URL where this server is hosted.
# Railway will give you a URL like: https://lighting-shoppe-mcp-production.up.railway.app
# For local development with a tunnel (e.g. ngrok): https://xxxx.ngrok.io
HOST=https://your-railway-app.up.railway.app

# Port to listen on. Railway sets this automatically; 3000 is fine for local dev.
PORT=3000

# ─── MCP Bearer Token ────────────────────────────────────────────────────────
# Secret token that Claude Desktop must send on every request to /sse and /messages.
# Without this, anyone who discovers your Railway URL can query your Shopify data.
#
# Generate a strong token (64 hex chars = 256 bits of entropy):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Then add it to Claude Desktop's claude_desktop_config.json:
#   "headers": { "Authorization": "Bearer <your-token-here>" }
MCP_BEARER_TOKEN=generate_with_node_command_above

# ─── Session Security ─────────────────────────────────────────────────────────
# A long random string used to sign session data.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_long_random_string_here

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "production" on Railway. Controls whether error details are exposed.
NODE_ENV=production
